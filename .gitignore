# Python
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
*.egg-info/
.installed.cfg
*.egg

# Virtual environments
venv/
env/
ENV/
.venv/

# IDE
.vscode/
.idea/
*.swp
*.swo
.DS_Store

# Jupyter
.ipynb_checkpoints/
*.ipynb

# Data files — never commit raw or derived data
*.csv
*.parquet
*.feather
*.h5
*.hdf5
*.pkl
*.pickle
data/
raw_data/

# Results — never commit; reproduce from code
results/
**/results/
*.json
!configs/*.yaml
!requirements.txt

# Paper artifacts — kept separately, never in code repo
paper/
manuscript/
docs/
**/figures/
**/tables/
*.pdf
*.png
*.jpg
*.jpeg
*.tif
*.docx
*.tex
*.md
!README.md
!revision1/code/README.md

# Cohort-specific config overrides (may contain protected identifiers)
configs/local_*.yaml
configs/*_private.yaml

# Temporary
*.log
*.tmp
.cache/
